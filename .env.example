# ── Sitio (SEO / Open Graph) ───────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://lacasadelallano.com

# ── Google Sheets + correo del local (automático con npm run setup:google) ──
# En producción: obligatorio para registrar reservas en el sistema del local.
GOOGLE_SHEETS_WEBHOOK_URL=
RESERVATION_WEBHOOK_SECRET=
RESTAURANT_EMAIL=reservas@lacasadelallano.com

# Desarrollo local: en `next dev` se activa solo si no pones false.
# Producción: opcional; sin Google Sheets el formulario igual abre WhatsApp.
RESERVATIONS_DEV_FALLBACK=true

# ── Correo alternativo vía Resend (opcional) ────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL="La Casa del Llano <reservas@tudominio.com>"

# ── Correo alternativo vía SMTP/Gmail (opcional) ────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="La Casa del Llano <tu-correo@gmail.com>"
